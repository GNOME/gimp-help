msgstr "Luminosità"

#: src/menus/colors/tone-mapping/reinhard.xml:108(para)
msgid "Overall brightness of the image."
msgstr "Luminosità complessiva dell'immagine."

#: src/menus/colors/tone-mapping/reinhard.xml:114(term)
msgid "Chromatic adaptation"
msgstr "Adattamento cromatico"

#: src/menus/colors/tone-mapping/reinhard.xml:116(para)
msgid "Adaptation to color variation across the image."
msgstr "Adattamento alle variazioni di colore nell'immagine."

#: src/menus/colors/tone-mapping/reinhard.xml:122(term)
msgid "Light adaptation"
msgstr "Adattamento di luce"

#: src/menus/colors/tone-mapping/reinhard.xml:124(para)
msgid "Adaptation to light variation across the image."
msgstr "Adattamento alle variazioni di luce nell'immagine."

