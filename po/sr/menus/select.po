#: src/menus/select/to-path.xml:9(title)
msgid "To Path"
msgstr "У путању"

#: src/menus/select/to-path.xml:11(primary)
#: src/menus/select/to-channel.xml:12(primary)
#: src/menus/select/shrink.xml:12(primary)
