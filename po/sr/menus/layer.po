msgid "Threshold Alpha"
msgstr "Праг алфе"

#: src/menus/layer/threshold-alpha.xml:14(secondary)
#: src/menus/layer/color-to-alpha.xml:17(secondary)
#: src/menus/layer/alpha-semi-flatten.xml:17(secondary)
