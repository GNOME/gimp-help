#. It doesn't matter what you translate it to: it's not used at all.
#: src/menus/colors/invert.xml:63(None)
msgid "@@image: 'images/menus/colors/invert-2.png'; md5=633e816d667a71710ef2a8bf7c964d49"
msgstr "@@image: 'images/menus/colors/invert-2.png'; md5=633e816d667a71710ef2a8bf7c964d49"

#: src/menus/colors/invert.xml:12(title) src/menus/colors/invert.xml:16(secondary)
msgid "Invert"
msgstr "Окрени"

#: src/menus/colors/invert.xml:19(primary) src/menus/colors/curves.xml:495(title)
msgid "Invert colors"
msgstr "Изврни боје"

#: src/menus/colors/invert.xml:22(para)
msgid "The <guimenuitem>Invert</guimenuitem> command inverts all the pixel colors and brightness values in the current layer, as if the image were converted into a negative. Dark areas become bright and bright areas become dark. Hues are replaced by their complementary colors. For more information about colors, see the Glossary entry about <link linkend=\"glossary-colormodel\">Color Model</link>."
msgstr "Наредба <guimenuitem>Изврни</guimenuitem> изврће све боје пиксела и вредности осветљења у тренутном слоју, као да је слика претворена у негатив. Тамне области постају светле, а светле области постају тамне. Нијансе се замењују својим допунским бојама. За више информација о бојама, погледајте ставку у Појмовнику о <link linkend=\"glossary-colormodel\">Моделу боја</link>."

#: src/menus/colors/invert.xml:40(para)
msgid "You can access this command from the main menu through <menuchoice><guimenu>Colors</guimenu><guimenuitem>Invert</guimenuitem></menuchoice>."
msgstr "Овој наредби можете приступити из главног менија преко <menuchoice><guimenu>Боје</guimenu><guimenuitem>Изврни</guimenuitem></menuchoice>."

#: src/menus/colors/invert.xml:52(title)
msgid "Applying <quote>Invert colors</quote>"
msgstr "Примена наредбе <quote>Изврни боје</quote>"

#: src/menus/colors/invert.xml:66(para)
msgid "After the colors were inverted"
msgstr "Након што су боје изврнуте"

