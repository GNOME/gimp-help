msgid "Color Management"
msgstr "Управљање бојама"

#: src/menus/view/view-soft-proof.xml:21(para)
msgid ""
"Enabling <guimenuitem>Proof Colors</guimenuitem> allows you to interpret the "
"colors of this view of your image using a soft-proofing profile that you can "
"set using <link linkend=\"gimp-image-soft-proof-profile-assign\">Soft-Proof "
"Profile</link>."
msgstr "Омогућавање опције <guimenuitem>Боје за симулацију</guimenuitem> вам омогућава да протумачите боје овог приказа ваше слике користећи профил за симулацију штампе који можете поставити помоћу ставке <link linkend=\"gimp-image-soft-proof-profile-assign\">Профил за симулацију штампе</link>."

