msgstr "Сепиа"

#: src/menus/colors/desaturate/sepia.xml:9(primary)
#: src/menus/colors/desaturate/desaturate.xml:11(primary)
#: src/menus/colors/desaturate/color-to-gray.xml:12(primary)
