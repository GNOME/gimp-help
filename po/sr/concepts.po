msgid ""
"@@image: 'images/dialogs/palette-editor-dialog.png'; "
"md5=df73871e2e1d24bf6fcb430bf9322381"
msgstr ""
"@@image: 'images/dialogs/palette-editor-dialog.png'; "
"md5=df73871e2e1d24bf6fcb430bf9322381"

