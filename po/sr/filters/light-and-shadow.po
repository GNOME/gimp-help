#: src/filters/light-and-shadow/bloom.xml:5(title)
#: src/filters/light-and-shadow/bloom.xml:10(tertiary)
#: src/filters/light-and-shadow/bloom.xml:13(primary)
msgid "Bloom"
msgstr "Цветање"

#: src/filters/light-and-shadow/bloom.xml:19(title)
msgid "Applying example for the Bloom filter"
msgstr "Пример примене за филтер „Цветање“"

#: src/filters/light-and-shadow/bloom.xml:39(para)
msgid "This filter adds a glow around bright areas."
msgstr "Овај филтер додаје сјај око светлих области."

#: src/filters/light-and-shadow/bloom.xml:46(para)
msgid ""
"This filter is found in the main menu under <menuchoice><guimenu>Filters</"
"guimenu><guisubmenu>Light and Shadow</guisubmenu><guimenuitem>Bloom…</"
"guimenuitem></menuchoice>."
msgstr ""
"Овај филтер се налази у главном менију под <menuchoice><guimenu>Филтери</"
"guimenu><guisubmenu>Светло и сенка</guisubmenu><guimenuitem>Цветање…</"
"guimenuitem></menuchoice>."

#: src/filters/light-and-shadow/bloom.xml:59(title)
msgid "<quote>Bloom</quote> filter options"
msgstr "Опције филтера <quote>Цветање</quote>"

#: src/filters/light-and-shadow/bloom.xml:83(para)
msgid "Glow area brightness threshold."
msgstr "Праг светлине области сјаја."

#: src/filters/light-and-shadow/bloom.xml:91(para)
msgid "Glow area edge softness."
msgstr "Мекоћа ивице области сјаја."

#: src/filters/light-and-shadow/bloom.xml:99(para)
msgid "The radius of the glow."
msgstr "Полупречник сјаја."

#: src/filters/light-and-shadow/bloom.xml:105(term)
msgid "Strength"
msgstr "Снага"

#: src/filters/light-and-shadow/bloom.xml:107(para)
msgid "The strength of the glow."
msgstr "Јачина сјаја."

#: src/filters/light-and-shadow/bloom.xml:113(term)
msgid "Limit exposure"
msgstr "Ограничи експозицију"

#: src/filters/light-and-shadow/bloom.xml:115(para)
msgid ""
"When enabled, it limits the exposure of highlights. This can be used to "
"reduce the glow in areas that are over exposed."
msgstr ""
"Када је омогућено, ограничава излагање истакнутих делова. Ово се може "
"користити за смањење сјаја у областима које су превише изложене."

