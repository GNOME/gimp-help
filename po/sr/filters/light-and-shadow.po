msgid ""
"@@image: 'images/filters/examples/light-taj-drop-shadow.jpg'; "
"md5=e2ad77b65e0f065caa75b251d8f6e11a"
msgstr ""
"@@image: 'images/filters/examples/light-taj-drop-shadow.jpg'; "
"md5=e2ad77b65e0f065caa75b251d8f6e11a"

