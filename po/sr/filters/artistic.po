#: src/filters/artistic/applycanvas.xml:71(None)
msgid "@@image: 'images/filters/artistic/apply_canvas-dialog.png'; md5=d1334b4d70029f6bb5ed632352d6ff98"
msgstr "@@image: 'images/filters/artistic/apply_canvas-dialog.png'; md5=d1334b4d70029f6bb5ed632352d6ff98"

#: src/filters/artistic/applycanvas.xml:8(title)
msgid "Apply Canvas"
msgstr "Примени платно"

#: src/filters/artistic/applycanvas.xml:13(tertiary) src/filters/artistic/applycanvas.xml:20(primary)
msgid "Canvas effect"
msgstr "Ефекат платна"

#: src/filters/artistic/applycanvas.xml:16(primary)
msgid "Canvas"
msgstr "Платно"

#: src/filters/artistic/applycanvas.xml:17(secondary)
msgid "effect"
msgstr "дејство"

#: src/filters/artistic/applycanvas.xml:26(title)
msgid "Example for the <quote>Apply Canvas</quote> filter"
msgstr "Пример за филтер <quote>Примени платно</quote>"

#: src/filters/artistic/applycanvas.xml:46(para)
msgid "This filter applies a canvas-like effect to the current layer or selection. It textures the image as if it were an artist's canvas."
msgstr "Овај филтер примењује ефекат сличан платну на тренутни слој или избор. Он текстурише слику као да је уметничко платно."

#: src/filters/artistic/applycanvas.xml:54(para)
msgid "This filter is found in the main menu under <menuchoice><guimenu>Filters</guimenu><guisubmenu>Artistic</guisubmenu><guimenuitem>Apply Canvas…</guimenuitem></menuchoice>."
msgstr "Овај филтер се налази у главном менију под <menuchoice><guimenu>Филтери</guimenu><guisubmenu>Уметнички</guisubmenu><guimenuitem>Примени платно…</guimenuitem></menuchoice>."

#: src/filters/artistic/applycanvas.xml:67(title)
msgid "<quote>Apply Canvas</quote> options"
msgstr "Опције за <quote>Примени платно</quote>"

#: src/filters/artistic/applycanvas.xml:89(term)
msgid "Direction"
msgstr "Смер"

#: src/filters/artistic/applycanvas.xml:91(para)
msgid "Direction sets the starting direction of the canvas render. You can also consider that this option gives you the position of the light source which lightens the canvas."
msgstr "Смер поставља почетни смер исцртавања платна. Такође можете сматрати да вам ова опција даје положај извора светлости који осветљава платно."

#: src/filters/artistic/applycanvas.xml:101(para)
msgid "The Depth slider controls the apparent depth of the rendered canvas effect from 1 (very flat) to 50 (very deep)."
msgstr "Клизач „Дубина“ управља привидном дубином исцртаног ефекта платна од 1 (веома равно) до 50 (веома дубоко)."

