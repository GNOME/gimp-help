#: src/filters/artistic/waterpixels.xml:10(title) src/filters/artistic/waterpixels.xml:15(tertiary) src/filters/artistic/waterpixels.xml:18(primary)
msgid "Waterpixels"
msgstr "Водени пиксели"

#: src/filters/artistic/waterpixels.xml:24(title)
msgid "Example for the <quote>Waterpixels</quote> filter"
msgstr "Пример за филтер <quote>Водени пиксели</quote>"

#: src/filters/artistic/waterpixels.xml:44(para)
msgid "Waterpixels is a filter based on superpixels and the watershed transformation. These algorithms are used to divide images in regions with similar color values."
msgstr "Водени пиксели је филтер заснован на суперпикселима и разводњеном преображају (watershed). Ови алгоритми се користе за дељење слика на области са сличним вредностима боје."

#: src/filters/artistic/waterpixels.xml:50(para)
msgid "This filter can be slow to update on larger images."
msgstr "Овај филтер може бити спор при ажурирању на већим сликама."

#: src/filters/artistic/waterpixels.xml:59(para)
msgid "This filter is found in the main menu under <menuchoice><guimenu>Filters</guimenu><guisubmenu>Artistic</guisubmenu><guimenuitem>Waterpixels…</guimenuitem></menuchoice>."
msgstr "Овај филтер се налази у главном менију под <menuchoice><guimenu>Филтери</guimenu><guisubmenu>Уметнички</guisubmenu><guimenuitem>Водени пиксели…</guimenuitem></menuchoice>."

