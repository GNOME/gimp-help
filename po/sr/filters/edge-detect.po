msgstr "Опције филтера „Прелив слике“"

#: src/filters/edge-detect/image_gradient.xml:97(term)
msgid "Output mode"
msgstr "Излазни режим"

#: src/filters/edge-detect/image_gradient.xml:99(para)
msgid "<guilabel>Magnitude</guilabel> is default: it combines both directions. <guilabel>Direction</guilabel>: only one direction is used. <guilabel>Both</guilabel> is like Magnitude."
msgstr "<guilabel>Интензитет</guilabel> је подразумеван: комбинује оба смера. <guilabel>Смер</guilabel>: користи се само један смер. <guilabel>Оба</guilabel> је исто што и „Интензитет“."

#: src/filters/edge-detect/image_gradient.xml:105(title)
msgid "Output mode examples"
msgstr "Примери режима излаза"

#: src/filters/edge-detect/image_gradient.xml:112(para)
msgid "Original image, with abrupt luminosity change"
msgstr "Изворна слика, са наглом променом осветљености"

#: src/filters/edge-detect/image_gradient.xml:121(para)
msgid "Option Magnitude is selected"
msgstr "Изабрана је опција Интензитет"

#: src/filters/edge-detect/image_gradient.xml:132(para)
msgid "Option Direction is selected. In result, black is no edge detected, white is edge detected."
msgstr "Изабрана је опција Смер. Као резултат, црна боја означава да ивица није откривена, а бела да јесте."

