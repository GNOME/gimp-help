#: src/filters/blur/pixelize.xml:99(term)
msgid "Block width"
msgstr ""

#: src/filters/blur/pixelize.xml:100(term)
msgid "Block height"
msgstr ""

#: src/filters/blur/pixelize.xml:102(para)
msgid "Here you can set the desired width and height of the blocks, in pixels."
