msgstr "или"

#: src/using/script-fu-gui-api.xml:94(para)
msgid "SF-COLOR \"label\" \"color\""
msgstr "SF-COLOR \"натпис\" \"боја\""

#: src/using/script-fu-gui-api.xml:104(seg)
