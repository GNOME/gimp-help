#: src/appendix/fdl.xml:216(title)
msgid "COPYING IN QUANTITY"
msgstr "УМНОЖАВАЊЕ У ВЕЋЕМ БРОЈУ"

#: src/appendix/fdl.xml:217(para)
msgid ""
