msgid "@@image: 'images/dialogs/patterns-dialog-list.png'; md5=81cc1fd9dbead5223cfc3fccbdc71c92"
msgstr "@@image: 'images/dialogs/patterns-dialog-list.png'; md5=81cc1fd9dbead5223cfc3fccbdc71c92"

