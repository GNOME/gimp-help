#: src/dialogs/prefs-window-management.xml:20(primary) src/dialogs/prefs-image-window.xml:8(title) src/dialogs/prefs-image-window.xml:13(tertiary) src/dialogs/prefs-image-window.xml:16(primary) src/dialogs/prefs-image-window-appearance.xml:12(tertiary) src/dialogs/prefs-image-window-appearance.xml:15(primary)
