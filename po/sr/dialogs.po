msgstr "@@image: 'images/dialogs/export-icns-dialog.png'; md5=2539e9541d17dd63bcaf08066e0319e6"

#: src/dialogs/file-icns-export.xml:5(title)
msgid "Export Image as ICNS"
msgstr "Извези слику као ICNS"

#: src/dialogs/file-icns-export.xml:7(primary)
msgid "Export Image as Apple Icon"
msgstr "Извези слику као Еплову иконицу"

#: src/dialogs/file-icns-export.xml:11(secondary)
msgid "icns"
msgstr "icns"

#: src/dialogs/file-icns-export.xml:18(title)
msgid "The Apple Icon Export dialog"
msgstr "Прозорче за извоз Еплове иконице"

#: src/dialogs/file-icns-export.xml:27(para)
msgid "The <ulink url=\"https://en.wikipedia.org/wiki/Apple_Icon_Image_format\">Apple Icon</ulink> format is used on macOS for displaying icons. It supports icons of 16 × 12, 16 × 16, 18 × 18, 24 × 24, 32 × 32, 36 × 36, 48 × 48, 64 × 64, 128 × 128, 256 × 256, 512 × 512 and 1024 × 1024 pixels. The fixed-size icons can be scaled by the operating system and displayed at any intermediate size."
msgstr "Формат <ulink url=\"https://en.wikipedia.org/wiki/Apple_Icon_Image_format\">Еплове иконице</ulink> се користи на macOS-у за приказивање иконица. Подржава иконице величина 16 × 12, 16 × 16, 18 × 18, 24 × 24, 32 × 32, 36 × 36, 48 × 48, 64 × 64, 128 × 128, 256 × 256, 512 × 512 и 1024 × 1024 пиксела. Иконице фиксне величине могу бити сразмерно увећане или умањене од стране оперативног система и приказане у било којој међувеличини."

#: src/dialogs/file-icns-export.xml:35(para)
msgid "The export dialog shows all the icons available. If there are invalid icon sizes, there will be a warning displayed. Layers with invalid sizes will not be exported. Layers will be shown from smallest to largest size, except that invalid sizes will be shown at the end."
msgstr "Прозорче за извоз приказује све доступне иконице. Ако постоје неисправне величине иконица, биће приказано упозорење. Слојеви са неисправним величинама неће бити извезени. Слојеви ће бити приказани од најмање до највеће величине, осим што ће неисправне величине бити приказане на крају."

#: src/dialogs/file-icns-export.xml:50(para)
msgid "When checked, the color profile will be saved with the image."
msgstr "Када је означено, профил боја ће бити сачуван уз слику."

