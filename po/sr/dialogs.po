msgid "@@image: 'images/preferences/prefs-canvas-interaction.png'; md5=41443d37565f3e9693a5cc3a561e4412"
msgstr "@@image: 'images/preferences/prefs-canvas-interaction.png'; md5=41443d37565f3e9693a5cc3a561e4412"

#: src/dialogs/prefs-canvas-interaction.xml:5(title) src/dialogs/prefs-canvas-interaction.xml:10(tertiary) src/dialogs/prefs-canvas-interaction.xml:13(primary) src/dialogs/prefs-canvas-interaction-modifiers.xml:13(primary)
msgid "Canvas Interaction"
msgstr "Интеракција са пратном"

#: src/dialogs/prefs-canvas-interaction.xml:18(title)
msgid "Canvas Interaction Preferences"
msgstr "Поставке интеракције са платном"

#: src/dialogs/prefs-canvas-interaction.xml:26(para)
msgid "This page lets you customize aspects of the behavior when interacting with the canvas."
msgstr "Ова страница вам омогућава да прилагодите аспекте понашања приликом интеракције са платном."

#: src/dialogs/prefs-canvas-interaction.xml:45(title)
msgid "Space Bar"
msgstr "Размакница"

#: src/dialogs/prefs-canvas-interaction.xml:47(primary)
msgid "Space bar"
msgstr "Размакница"

#: src/dialogs/prefs-canvas-interaction.xml:50(term)
msgid "While space bar is pressed"
msgstr "Док је притиснута размакница"

#: src/dialogs/prefs-canvas-interaction.xml:54(para)
msgid "<guilabel>Pan view</guilabel> (default) or"
msgstr "<guilabel>Померање приказа</guilabel> (подразумевано) или"

#: src/dialogs/prefs-canvas-interaction.xml:57(guilabel)
msgid "Toggle to Move Tool"
msgstr "Пребаци на алат за премештање"

#: src/dialogs/prefs-canvas-interaction.xml:60(guilabel)
msgid "No action"
msgstr "Без акције"

#: src/dialogs/prefs-canvas-interaction.xml:72(term)
msgid "Drag-to-zoom behavior"
msgstr "Понашање приликом превлачења за увећање"

#: src/dialogs/prefs-canvas-interaction.xml:74(para)
msgid "This setting decides how zooming with the <link linkend=\"gimp-tool-zoom\">Zoom tool</link> works. By default, the amount of zooming is <guilabel>By distance</guilabel>. The farther you drag the zoom rectangle, the larger the amount of zooming."
msgstr "Ово подешавање одређује како ради увећање помоћу <link linkend=\"gimp-tool-zoom\">алата за увећање</link>. Подразумевано, количина увећања је <guilabel>Према растојању</guilabel>. Што даље превучете правоугаоник за увећање, то је већа количина увећања."

#: src/dialogs/prefs-canvas-interaction.xml:81(para)
msgid "You can also choose for zooming <guilabel>By duration</guilabel>. In this case, the amount of zooming depends on the time spent dragging."
msgstr "Такође можете изабрати увећање <guilabel>Према трајању</guilabel>. У том случају, количина увећања зависи од времена проведеног у превлачењу."

#: src/dialogs/prefs-canvas-interaction.xml:89(term)
msgid "Drag-to-zoom speed"
msgstr "Брзина превлачења за увећање"

#: src/dialogs/prefs-canvas-interaction.xml:91(para)
msgid "This adjusts the rate at which dragging the mouse will zoom the canvas, as a percentage."
msgstr "Ово подешава брзину којом ће превлачење мишем увећавати платно, изражено у процентима."

#. When image changes, this message will be marked fuzzy or untranslated for you.
#. It doesn't matter what you translate it to: it's not used at all.
#: src/dialogs/prefs-canvas-interaction-snapping.xml:22(None)
msgid "@@image: 'images/preferences/prefs-canvas-interaction-snapping.png'; md5=a0126e641decc9ee527b426d82e8138b"
msgstr "@@image: 'images/preferences/prefs-canvas-interaction-snapping.png'; md5=a0126e641decc9ee527b426d82e8138b"

#: src/dialogs/prefs-canvas-interaction-snapping.xml:8(title)
msgid "Canvas Interaction Snapping Behavior"
msgstr "Понашање пријањања при интеракцији са платном"

#: src/dialogs/prefs-canvas-interaction-snapping.xml:11(secondary) src/dialogs/prefs-canvas-interaction-snapping.xml:14(primary)
msgid "Snapping"
msgstr "Пријањање"

#: src/dialogs/prefs-canvas-interaction-snapping.xml:18(title)
msgid "Snapping Behavior Preferences"
msgstr "Поставке понашања пријањања"

#: src/dialogs/prefs-canvas-interaction-snapping.xml:27(para)
msgid "This page allows you to customize the default settings for snapping in an image. These settings can be set separately for working in normal mode and in fullscreen mode."
msgstr "Ова страница вам омогућава да прилагодите подразумевана подешавања за пријањање на слици. Ова подешавања се могу поставити засебно за рад у нормалном режиму и у режиму преко целог екрана."

#: src/dialogs/prefs-canvas-interaction-snapping.xml:50(para)
msgid "The following snap settings can be adjusted. We link to the documentation in the View menu for details about each setting."
msgstr "Следећа подешавања пријањања се могу прилагодити. Повезујемо на документацију у менију „Преглед“ за детаље о сваком подешавању."

#: src/dialogs/prefs-canvas-interaction-snapping.xml:56(para)
msgid "<link linkend=\"gimp-view-snap-to-guides\">Snap to Guides</link>. This is the only type of snapping enabled by default."
msgstr "<link linkend=\"gimp-view-snap-to-guides\">Приони на вођице</link>. Ово је једина врста пријањања која је подразумевано омогућена."

#: src/dialogs/prefs-canvas-interaction-snapping.xml:62(para)
msgid "<link linkend=\"gimp-view-snap-to-grid\">Snap to Grid</link>."
msgstr "<link linkend=\"gimp-view-snap-to-grid\">Приони на мрежу</link>."

#: src/dialogs/prefs-canvas-interaction-snapping.xml:67(para)
msgid "<link linkend=\"gimp-view-snap-to-canvas\">Snap to Canvas Edges</link>."
msgstr "<link linkend=\"gimp-view-snap-to-canvas\">Приони на ивице платна</link>."

#: src/dialogs/prefs-canvas-interaction-snapping.xml:72(para)
msgid "<link linkend=\"gimp-view-snap-to-path\">Snap to Active Path</link>."
msgstr "<link linkend=\"gimp-view-snap-to-path\">Приони на активну путању</link>."

#: src/dialogs/prefs-canvas-interaction-snapping.xml:77(para)
msgid "<link linkend=\"gimp-view-snap-to-bbox\">Snap to Bounding Box</link>."
msgstr "<link linkend=\"gimp-view-snap-to-bbox\">Приони на гранични оквир</link>."

#: src/dialogs/prefs-canvas-interaction-snapping.xml:82(para)
msgid "<link linkend=\"gimp-view-snap-to-equidistance\">Snap to Equidistance</link>."
msgstr "<link linkend=\"gimp-view-snap-to-equidistance\">Приони на еквидистанцу</link>."

#: src/dialogs/prefs-canvas-interaction-snapping.xml:87(para)
msgid "<guilabel>Snapping distance</guilabel> is the activation distance of snapping, in pixels. That is, how close an object needs to be for snapping to happen. The default value is 8 pixels, allowed values are in the range of 1-255."
msgstr "<guilabel>Растојање пријањања</guilabel> је удаљеност активирања пријањања, у пикселима. То јест, колико близу објекат треба да буде да би дошло до пријањања. Подразумевана вредност је 8 пиксела, а дозвољене вредности су у опсегу од 1 до 255."

#. When image changes, this message will be marked fuzzy or untranslated for you.
#. It doesn't matter what you translate it to: it's not used at all.
#: src/dialogs/prefs-canvas-interaction-modifiers.xml:22(None)
msgid "@@image: 'images/preferences/prefs-canvas-interaction-modifiers.png'; md5=2d4b98c12c5961cfb48d69d32d4939fc"
msgstr "@@image: 'images/preferences/prefs-canvas-interaction-modifiers.png'; md5=2d4b98c12c5961cfb48d69d32d4939fc"

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:5(title)
msgid "Canvas Interaction Modifiers"
msgstr "Измењивачи интеракције са платном"

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:10(tertiary) src/dialogs/prefs-canvas-interaction-modifiers.xml:47(title) src/dialogs/path-dialog.xml:430(segtitle)
msgid "Modifiers"
msgstr "Заменски тастери"

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:18(title)
msgid "Modifiers Preferences"
msgstr "Поставке измењивача"

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:26(para)
msgid "This page allows you to change the key modifiers for any of the available buttons of your input devices (mouse, stylus, etc.), except for the primary button. This can be used to change the actions performed on the canvas when a certain button in combination with a key modifier is pressed."
msgstr "Ова страница вам омогућава да промените тастере измењиваче за било које доступно дугме ваших улазних уређаја (миш, оловка, итд.), осим за главно дугме. Ово се може користити за промену радњи које се обављају на платну када се притисне одређено дугме у комбинацији са тастером измењивачем."

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:49(term)
msgid "Click here to set a button's modifiers"
msgstr "Кликните овде да поставите тастере као измењиваче"

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:51(para)
msgid "Clicking on this button with one of the buttons of your input devices (except the primary button) allows you to change the command that each modifier for that button performs when used."
msgstr "Клик на ово дугме једним од дугмића ваших улазних уређаја (осим главног дугмета) омогућава вам да промените наредбу коју сваки измењивач за то дугме обавља када се користи."

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:56(para)
msgid "When clicked, it shows a list of the current commands assigned to each of the modifiers for the button you clicked. Only the modifiers that have commands attached to them will be shown. You can add a new item to the list by clicking the button below the list, or remove a modifier that you don't need by clicking the button to the right of each item."
msgstr "Када се кликне, приказује се списак тренутних наредби додељених сваком од измењивача за дугме које сте кликнули. Биће приказани само измењивачи који имају приложене наредбе. Можете додати нову ставку на списак кликом на дугме испод списка, или уклонити измењивач који вам није потребан кликом на дугме десно од сваке ставке."

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:64(para)
msgid "To change what a modifier does, click on the list, which will show you all available choices. To change the modifier that performs a command click on the modifier column on the left and press the modifier or modifiers that you would like to use. Multiple modifiers are allowed, e.g. Shift+Ctrl+middle mouse button (shown as button 2 of System Aggregated Pointer), is by default attached to <guilabel>Rotate View by 15 degree steps</guilabel>."
msgstr "Да бисте променили шта измењивач ради, кликните на списак, који ће вам приказати све доступне изборе. Да бисте променили измењивач који обавља наредбу, кликните на колону измењивача на левој страни и притисните измењивач или измењиваче које желите да користите. Дозвољено је више измењивача, нпр. Shift+Ctrl+средње дугме миша (приказано као дугме 2 Системског збирног показивача), подразумевано је приложено уз <guilabel>Ротирај приказ у корацима од 15 степени</guilabel>."

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:76(term)
msgid "Reset Saved Modifiers Settings to Default Values"
msgstr "Врати сачувана подешавања измењивача на подразумеване вредности"

#: src/dialogs/prefs-canvas-interaction-modifiers.xml:78(para)
msgid "Clicking this button resets all modifiers for your input devices to their default values."
msgstr "Клик на ово дугме враћа све измењиваче за ваше улазне уређаје на њихове подразумеване вредности."

#. When image changes, this message will be marked fuzzy or untranslated for you.
#. It doesn't matter what you translate it to: it's not used at all.
#: src/dialogs/pointer-dialog.xml:24(None)
msgid "@@image: 'images/dialogs/pointer-dialog.png'; md5=f09326f5dea78d4992a02d5a00a20dd0"
msgstr "@@image: 'images/dialogs/pointer-dialog.png'; md5=f09326f5dea78d4992a02d5a00a20dd0"

#: src/dialogs/pointer-dialog.xml:11(title)
msgid "Pointer Dialog"
msgstr "Прозорче за показивач"

#: src/dialogs/pointer-dialog.xml:14(secondary) src/dialogs/pointer-dialog.xml:17(primary)
msgid "Pointer"
msgstr "Показивач"

#: src/dialogs/pointer-dialog.xml:21(title)
msgid "Pointer dialog"
msgstr "Прозорче за показивач"

#: src/dialogs/pointer-dialog.xml:29(para)
msgid "This dialog offers you, in a same window, in real time, the position of the mouse pointer, and the channel values of the pointed pixel, in the chosen color model."
msgstr "Ово прозорче вам нуди, у истом прозору, у реалном времену, положај показивача миша и вредности канала означеног пиксела, у изабраном моделу боја."

#: src/dialogs/pointer-dialog.xml:47(para)
msgid "from the main menu: <menuchoice><guimenu>Windows</guimenu><guisubmenu>Dockable Dialogs</guisubmenu><guimenuitem>Pointer</guimenuitem></menuchoice>."
msgstr "из главног менија: <menuchoice><guimenu>Прозори</guimenu><guisubmenu>Прикачиви прозорчићи</guisubmenu><guimenuitem>Показивач</guimenuitem></menuchoice>."

#: src/dialogs/pointer-dialog.xml:57(para)
msgid "from the Tab menu in any dockable dialog by clicking the <link linkend=\"tab-menus\">tab menu button</link><placeholder-1/> and selecting <menuchoice><guimenu>Add Tab</guimenu><guimenuitem>Pointer</guimenuitem></menuchoice>."
msgstr "из менија језичака у било ком прикачивом прозорчету кликом на <link linkend=\"tab-menus\">дугме менија језичака</link><placeholder-1/> и избором <menuchoice><guimenu>Додај језичак</guimenu><guimenuitem>Показивач</guimenuitem></menuchoice>."

#: src/dialogs/pointer-dialog.xml:78(title)
msgid "<quote>Pointer</quote> dialog options"
msgstr "Опције прозорчета „<quote>Показивач</quote>“"

#: src/dialogs/pointer-dialog.xml:81(term)
msgid "Pixels"
msgstr "Пиксели"

#: src/dialogs/pointer-dialog.xml:83(para)
msgid "Shows the position of the pointed pixel, in X (horizontal) and Y (vertical) coordinates, stated in pixels from the origin (the upper left corner of the canvas)."
msgstr "Приказује положај тачке на коју показујете, у X (водоравним) и Y (усправним) координатама, израженим у пикселима од почетка (горњи леви угао платна)."

#: src/dialogs/pointer-dialog.xml:91(term)
msgid "Units"
msgstr "Јединице"

#: src/dialogs/pointer-dialog.xml:93(para)
msgid "Shows the distance from the origin, in inches."
msgstr "Приказује удаљеност од почетка, у инчима."

#: src/dialogs/pointer-dialog.xml:99(term)
msgid "Pointer Bounding Box"
msgstr "Гранични оквир показивача"

#: src/dialogs/pointer-dialog.xml:101(para)
msgid "This information is active when a selection exists. X and Y are the coordinates of the upper left corner of the rectangular frame that bounds rectangular and ellipse selections. H and W are the height and width of this box."
msgstr "Ови подаци су активни када постоји избор. X и Y су координате горњег левог угла правоугаоног кадра који ограничава правоугаоне и елиптичне изборе. H и W су висина и ширина овог оквира."

#: src/dialogs/pointer-dialog.xml:107(para)
msgid "This information also exits for the other selections, but they are of less interest and the bounding box is not visible."
msgstr "Ови подаци постоје и за остале изборе, али су они мање занимљиви и гранични оквир није видљив."

#: src/dialogs/pointer-dialog.xml:111(para)
msgid "This information concerning the selection remains unchanged when you use another tool, while pointer coordinates vary."
msgstr "Ови подаци који се тичу избора остају непромењени када користите другу алатку, док се координате показивача мењају."

#: src/dialogs/pointer-dialog.xml:118(term)
msgid "Channel values"
msgstr "Вредности канала"

#: src/dialogs/pointer-dialog.xml:121(para)
msgid "The channel values for the selected <link linkend=\"glossary-colormodel\">color model</link> are shown below. Both pulldown menus contain the same choices, which makes it easier for you to compare the color values of a particular pixel using different color models. <quote>Hex</quote> is the <link linkend=\"glossary-html-notation\">HTML Notation</link> of the pixel color, in hexadecimal. The choices on the pulldown menus are (<guilabel>Pixel</guilabel> is the default):"
msgstr "Вредности канала за изабрани <link linkend=\"glossary-colormodel\">модел боје</link> су приказане испод. Оба падајућа менија садрже исте изборе, што вам олакшава поређење вредности боја одређене тачке користећи различите моделе боја. „<quote>Hex</quote>“ је <link linkend=\"glossary-html-notation\">ХТМЛ запис</link> боје тачке, хексадецимално. Избори у падајућим менијима су (подразумевано је <guilabel>Пиксел</guilabel>):"

#: src/dialogs/pointer-dialog.xml:135(para)
msgid "The <link linkend=\"glossary-rgb\">RGB</link> channel values. This choice displays the <emphasis>Red</emphasis>, <emphasis>Green</emphasis>, <emphasis>Blue</emphasis> and <emphasis>Alpha</emphasis> values of the pixel, as numbers between 0 and 255."
msgstr "Вредности <link linkend=\"glossary-rgb\">РГБ</link> канала. Овај избор приказује вредности <emphasis>црвене</emphasis>, <emphasis>зелене</emphasis>, <emphasis>плаве</emphasis> и <emphasis>алфа</emphasis> компоненте тачке, као бројеве између 0 и 255."

#: src/dialogs/pointer-dialog.xml:145(term) src/dialogs/histogram-dialog.xml:191(term) src/dialogs/heif-avif-common-options.xml:60(term) src/dialogs/gradient-editor-dialog.xml:513(term) src/dialogs/gradient-editor-dialog.xml:515(para)
msgid "RGB"
msgstr "РГБ"

#: src/dialogs/pointer-dialog.xml:147(para)
msgid "The <link linkend=\"glossary-rgb\">RGB</link> channel values. This choice displays the <emphasis>Red</emphasis>, <emphasis>Green</emphasis>, <emphasis>Blue</emphasis> and <emphasis>Alpha</emphasis> values of the pixel, as percentages. It also shows the hexadecimal value of the pixel's color."
msgstr "Вредности <link linkend=\"glossary-rgb\">РГБ</link> канала. Овај избор приказује вредности <emphasis>црвене</emphasis>, <emphasis>зелене</emphasis>, <emphasis>плаве</emphasis> и <emphasis>алфа</emphasis> компоненте тачке, у процентима. Такође приказује хексадецималну вредност боје тачке."

#: src/dialogs/pointer-dialog.xml:160(para)
msgid "The <link linkend=\"glossary-hsv\">HSV</link> components. This choice displays the <emphasis>Hue</emphasis>, in degrees, as well as the <emphasis>Saturation</emphasis>, <emphasis>Value</emphasis> and <emphasis>Alpha</emphasis> of the pixel, as percentages."
msgstr "<link linkend=\"glossary-hsv\">ХСВ</link> компоненте. Овај избор приказује <emphasis>нијансу</emphasis>, у степенима, као и <emphasis>засићеност</emphasis>, <emphasis>вредност</emphasis> и <emphasis>алфа</emphasis> компоненту тачке, у процентима."

#: src/dialogs/pointer-dialog.xml:172(para)
msgid "The <link linkend=\"glossary-cmyk\">CMYK</link> channel values. This choice displays the <emphasis>Cyan</emphasis>, <emphasis>Magenta</emphasis>, <emphasis>Yellow</emphasis>, <emphasis>Black</emphasis> and <emphasis>Alpha</emphasis> values of the pixel, as percentages."
msgstr "Вредности <link linkend=\"glossary-cmyk\">ЦМИК</link> канала. Овај избор приказује вредности <emphasis>цијан</emphasis>, <emphasis>магента</emphasis>, <emphasis>жуте</emphasis>, <emphasis>црне</emphasis> и <emphasis>алфа</emphasis> компоненте тачке, у процентима."

#: src/dialogs/pointer-dialog.xml:185(term)
msgid "Sample Merged"
msgstr "Спојени узорак"

#: src/dialogs/pointer-dialog.xml:188(para)
msgid "If you enable this option, sampling is not calculated only from the values of the active layer, but from all visible layers."
msgstr "Ако омогућите ову опцију, узорковање се не израчунава само на основу вредности активног слоја, већ на основу свих видљивих слојева."

#: src/dialogs/pointer-dialog.xml:192(para) src/dialogs/palettes-dialog.xml:389(para)
msgid "For more information, see the <link linkend=\"glossary-samplemerge\">Glossary entry</link>."
msgstr "За више података, погледајте <link linkend=\"glossary-samplemerge\">унос у појмовнику</link>."

